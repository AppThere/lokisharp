# Normalise line endings to LF in repo, checkout as-is
* text=auto eol=lf

# Binary assets — no line ending normalisation
*.png binary
*.jpg binary
*.jpeg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.pdf binary
*.nupkg binary
*.snupkg binary
*.docx binary
*.xlsx binary
*.pptx binary

# Enforce LF for all text source files
*.cs text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.editorconfig text eol=lf
